# syntax=docker/dockerfile:1.7@sha256:a57df69d0ea827fb7266491f2813635de6f17269be881f696fbfdf2d83dda33e
ARG GO_BUILD_IMAGE=golang:1.25.12-alpine3.23@sha256:cc985ef6f9c3bf9ece7488129c9abe0a150388ccdfa428d886fc709dca0b230a
ARG RUNTIME_IMAGE=alpine:3.22@sha256:14358309a308569c32bdc37e2e0e9694be33a9d99e68afb0f5ff33cc1f695dce
FROM --platform=$TARGETPLATFORM ${GO_BUILD_IMAGE} AS build
WORKDIR /src
COPY go.mod go.sum ./
COPY tests/e2e/fake-runner ./tests/e2e/fake-runner
ARG GOPROXY=https://proxy.golang.org,direct
ARG TARGETOS=linux
ARG TARGETARCH
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -trimpath -buildvcs=false -ldflags='-s -w' -o /out/fake-runner ./tests/e2e/fake-runner

FROM ${RUNTIME_IMAGE}
LABEL org.opencontainers.image.title="AJiaSu Fake Runner" \
      org.opencontainers.image.description="Test-only deterministic Runner relay boundary" \
      org.opencontainers.image.licenses="Apache-2.0" \
      io.ajiasu.test-only="true"
RUN addgroup -g 65532 -S runner && adduser -S -D -H -u 65532 -G runner runner \
    && mkdir -p /run/ajiasu-relay \
    && chown 65532:65532 /run/ajiasu-relay
COPY --from=build --chown=0:0 --chmod=0555 /out/fake-runner /usr/local/bin/fake-runner
USER 65532:65532
ENV AJIASU_RUNNER_RELAY_SOCKET=/run/ajiasu-relay/runner.sock
HEALTHCHECK --interval=2s --timeout=1s --start-period=2s --retries=10 CMD ["/usr/local/bin/fake-runner", "health"]
ENTRYPOINT ["/usr/local/bin/fake-runner"]
